<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:Domain.Models.Entities;assembly=Domain.Models"
    xmlns:viewModels="clr-namespace:InfoBoard.Presentation.ViewModels"
    x:Class="InfoBoard.Presentation.MainPage"
    x:DataType="viewModels:MainPageViewModel"
    BackgroundColor="#000000">
    <ContentPage.Background>
        <LinearGradientBrush EndPoint="1,0">
            <GradientStop Color="CadetBlue" Offset="0.1"/>
            <GradientStop Color="MediumPurple" Offset="1.0"/>
        </LinearGradientBrush>
    </ContentPage.Background>
    <Grid Padding="20" RowSpacing="20" ColumnSpacing="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="2.5*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!--Vädret-->
        <Border Grid.Row="0" Grid.Column="0"
                BackgroundColor="#121212"
                Padding="20"
                Stroke="#333"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">

            <VerticalStackLayout Spacing="10">
                <Label Text="WEATHER"
                       FontSize="12"
                       FontAttributes="Bold"
                       TextColor="#66C0F4"
                       CharacterSpacing="1.5"/>

                <Label x:Name="CurrentTemperature"
                       Text="{Binding Weather.Temp}"
                       FontSize="48"
                       FontAttributes="Bold"
                       TextColor="White"
                       Margin="0,5,0,0"/>

                <Label x:Name="CurrentCity"
                       Text="{Binding Weather.CityDisplay}"
                       FontSize="14"
                       TextColor="#777777"
                       Margin="0,-5,0,0"/>

                <Label x:Name="CurrentHumidity"
                       Text="{Binding Weather.Hum}"
                       FontSize="12"
                       TextColor="#555555"
                       Margin="0,5,0,10"/>

                <Entry Placeholder="Select City"
                       Text="{Binding Weather.CityInputText, Mode=TwoWay}"
                       TextColor="White"
                       PlaceholderColor="#444"/>

                <Button Text="Update"
                        BackgroundColor="#a29bfe"
                        TextColor="Black"
                        FontAttributes="Bold"
                        HeightRequest="40"
                        Command="{Binding Weather.UpdateWeatherCommand}"/>
            </VerticalStackLayout>
        </Border>
        <!--Rss feeden-->

        <Border Grid.Column="1" 
                BackgroundColor="#121212" 
                Stroke="#333" 
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">

            <Grid RowDefinitions="Auto, *">
                <VerticalStackLayout Grid.Row="0" Padding="20,20,20,5">
                    <Label Text="LATEST NEWS" 
                           TextColor="#66C0F4" 
                           FontAttributes="Bold" 
                           FontSize="12" 
                           CharacterSpacing="1.5"/>
                    <BoxView HeightRequest="1" Color="#222" Margin="0,10,0,0"/>
                </VerticalStackLayout>

                <RefreshView Grid.Row="1" x:Name="RssRefreshView" RefreshColor="#a29bfe">
                    <CollectionView x:Name="RssListView" 
                                    SelectionMode="Single"
                                    SelectionChanged="OnRssSelectionChanged"
                                    EmptyView="Loading news...">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:RssItem">
                                <Grid Padding="20,12" ColumnDefinitions="Auto, *">
                                    <Label Text="{Binding PublishDate}" 
                                           TextColor="#555" 
                                           FontSize="11" 
                                           FontFamily="Monospace"
                                           VerticalOptions="Start"
                                           Margin="0,2,15,0"/>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="{Binding Title}" 
                                               TextColor="White" 
                                               FontSize="14" 
                                               LineBreakMode="WordWrap"/>
                                        <Label Text="SVT News" 
                                               TextColor="#333" 
                                               FontSize="10"/>
                                    </VerticalStackLayout>
                                </Grid>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </RefreshView>
            </Grid>
        </Border>
        <!--Valda servrar-->
        <Border Grid.Row="0" Grid.Column="2" 
                BackgroundColor="#121212" 
                Padding="20" 
                Stroke="#333"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">
            <VerticalStackLayout Spacing="12">
                <Label Text="GAME SERVERS" 
                       TextColor="#66C0F4" 
                       FontSize="12" 
                       FontAttributes="Bold" 
                       CharacterSpacing="1.5"/>

                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Game.SelectedServers}">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate x:DataType="models:GameTimeItem">
                            <Grid ColumnDefinitions="*, Auto" Margin="0,8">
                                <VerticalStackLayout>
                                    <Label Text="{Binding Game}" FontSize="10" TextColor="#777777"/>
                                    <Label Text="{Binding Name}" FontSize="14" TextColor="White"/>
                                </VerticalStackLayout>
                                <Label Grid.Column="1" 
                       Text="{Binding DisplayTime}" 
                       TextColor="White" />
                            </Grid>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

                <Button Text="Manage"
                        BackgroundColor="#a29bfe"
                        TextColor="Black"
                        FontAttributes="Bold"
                        Margin="0,10,0,0"
                        Clicked="OnClickGoManage"/>
            </VerticalStackLayout>
        </Border>
        <!--Lägga till nya tasks-->
        <Border Grid.Row="1" Grid.ColumnSpan="3"
                BackgroundColor="#121212"
                Padding="20"
                Stroke="#333"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 16">

            <Grid ColumnDefinitions="*, 1.5*">
                <VerticalStackLayout Spacing="15" Grid.Column="0">
                    <Label Text="TASKS"/>

                    <Entry Text="{Binding ToDo.NewToDoTitle, Mode=TwoWay}" 
                    Placeholder="New Task..." 
                    TextColor="White"
                    PlaceholderColor="#444"/>

                    <Button Text="Save choice" 
                    BackgroundColor="#a29bfe"
                    TextColor="Black"
                    FontAttributes="Bold"
                    Command="{Binding ToDo.AddCommand}"  
                    Margin="0,15,0,0" 
                    HeightRequest="45"
                    WidthRequest="200"
                    HorizontalOptions="Start"/>

                    <Button Text="Remove selected" 
                    BackgroundColor="Transparent"
                    BorderColor="#e74c3c"
                    BorderWidth="1"
                    TextColor="#e74c3c"
                    FontAttributes="Bold"
                    Command="{Binding ToDo.RemoveFinishedCommand}"  
                    Margin="0,5,0,0" 
                    HeightRequest="45"
                    WidthRequest="200"
                    HorizontalOptions="Start"/>
                    
                    <!--Progress bar-->
                    <VerticalStackLayout Spacing="5">
                        <Label Text="{Binding ToDo.ProgressText}"
               FontSize="12"
               TextColor="#777777"/>
                        <ProgressBar Progress="{Binding ToDo.ToDoProgress}"
                     ProgressColor="#a29bfe"
                     HeightRequest="8"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>
                <!--ToDo Listan-->
                <CollectionView ItemsSource="{Binding ToDo.Todos}" Grid.Column="1" Margin="20,0,0,0">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:TodoItem">
                            <Grid ColumnDefinitions="Auto, *" Padding="0,5">
                                <CheckBox IsChecked="{Binding IsCompleted}" 
                          Color="#a29bfe"
                          CheckedChanged="OnClickUpdateFile"/>
                                <Label Grid.Column="1" 
                       Text="{Binding Title}" 
                       TextColor="White" 
                       FontSize="16"
                       VerticalOptions="Center" />
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>
        </Border>
    </Grid>
</ContentPage>